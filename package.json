    "url": "https://github.com/timmeinerzhagen/dependabot-sha-comment-action/issues"
  },
  "homepage": "https://github.com/timmeinerzhagen/dependabot-sha-comment-action#readme",
  "devDependencies": {
    "@types/jest": "^28.1.2",
    "@types/node": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^5.28.0",
    "@typescript-eslint/parser": "^5.28.0",
    "esbuild": "^0.14.46",
    "eslint": "^8.18.0",
    "jest": "^28.1.1",
    "ts-jest": "^28.0.5",
    "typescript": "^4.7.4"
  },
  "dependencies": {

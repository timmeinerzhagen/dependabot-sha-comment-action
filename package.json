{
  "name": "dependabot-sha-comment-action",
  "version": "2.0.0",
  "description": "Update version comment for SHA pin of GitHub Actions on Dependabot update.",
  "main": "dist/index.js",
  "scripts": {
    "build": "./build.js",
    "lint": "eslint . --ext .ts",
    "start": "npm run lint && npm run build && echo \"Run JS via Node\" && npm run exec",
    "exec": "node -e \"require('./dist/index');\"",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/timmeinerzhagen/dependabot-sha-comment-action.git"
  },
